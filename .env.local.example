# ---- Supabase (get these from your Supabase project: Settings > API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The public URL of this app (used for auth redirects).
# Local: http://localhost:3000   Production: https://app.sellhi.ai
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Meetings & Prep module (all OPTIONAL; features degrade gracefully) ----
# Prep-notes + scribble work with NONE of these set. Add each to light up a piece.

# Calendar OAuth (Meetings surface). Register the redirect URIs shown in
# MEETINGS-SPEC.md. Leave unset to keep the "Connect calendar" state.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Fireflies (meeting transcript + summary). Leave unset for "Connect Fireflies".
FIREFLIES_API_KEY=

# Common Room (common connections). Leave unset for "Connect Common Room".
COMMON_ROOM_API_KEY=

# ---- Stripe billing (subscriptions) ----
# Use TEST keys (sk_test_..., whsec_...) until you've verified the full flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Service-role key for the webhook to write connect_config (bypasses RLS).
# Supabase > Project Settings > API > service_role (SECRET — never expose client-side).
SUPABASE_SERVICE_ROLE_KEY=
# Price IDs (create Products+Prices in Stripe, paste each price id here).
STRIPE_PRICE_SEED_MONTHLY=
STRIPE_PRICE_SEED_ANNUAL=
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_ANNUAL=
STRIPE_PRICE_SCALEMANAGED_MONTHLY=
STRIPE_PRICE_SCALEMANAGED_ANNUAL=
